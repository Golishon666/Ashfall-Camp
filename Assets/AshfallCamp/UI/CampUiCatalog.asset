  ToastMessages:
  - Id: action_blocked
    TitleFormat: ACTION BLOCKED
    BodyFormat: '{0}'
    ToneColor: {r: 0.7882353, g: 0.3882353, b: 0.22745098, a: 1}
  - Id: no_idle_survivors
    TitleFormat: NO CREW READY
    BodyFormat: All available survivors are busy or wounded.
    ToneColor: {r: 0.7882353, g: 0.3882353, b: 0.22745098, a: 1}
  - Id: building_upgraded
    TitleFormat: BUILDING UPGRADED
    BodyFormat: '{0} reached level {1}.'
    ToneColor: {r: 0.48235294, g: 0.5411765, b: 0.41960785, a: 1}
  - Id: expedition_launched
    TitleFormat: EXPEDITION LAUNCHED
    BodyFormat: '{0} route is underway.'
    ToneColor: {r: 0.18431373, g: 0.41568628, b: 0.44705883, a: 1}
  - Id: expedition_completed
    TitleFormat: REPORT READY
    BodyFormat: '{0} team returned. After Action is open.'
    ToneColor: {r: 0.48235294, g: 0.5411765, b: 0.41960785, a: 1}
  - Id: expedition_failed
    TitleFormat: EXPEDITION FAILED
    BodyFormat: '{0} report is ready. Review losses and loot.'
    ToneColor: {r: 0.7882353, g: 0.3882353, b: 0.22745098, a: 1}
  - Id: offline_report_ready
    TitleFormat: OFFLINE REPORT
    BodyFormat: Camp progress from {0} min away is ready.
    ToneColor: {r: 0.18431373, g: 0.41568628, b: 0.44705883, a: 1}
  - Id: recruitment_broadcast
    TitleFormat: BROADCAST SENT
    BodyFormat: '{0} signal candidates found.'
    ToneColor: {r: 0.18431373, g: 0.41568628, b: 0.44705883, a: 1}
  - Id: recruitment_skipped
    TitleFormat: SIGNALS CLEARED
    BodyFormat: Current candidate signals were dismissed.
    ToneColor: {r: 0.41568628, g: 0.3647059, b: 0.2901961, a: 1}
  - Id: survivor_recruited
    TitleFormat: SURVIVOR JOINED
    BodyFormat: '{0} joined the camp.'
    ToneColor: {r: 0.48235294, g: 0.5411765, b: 0.41960785, a: 1}
  - Id: item_repaired
    TitleFormat: ITEM REPAIRED
    BodyFormat: '{0} is ready for field work.'
    ToneColor: {r: 0.48235294, g: 0.5411765, b: 0.41960785, a: 1}
  - Id: item_equipped
    TitleFormat: ITEM EQUIPPED
    BodyFormat: '{0} equipped {1}.'
    ToneColor: {r: 0.18431373, g: 0.41568628, b: 0.44705883, a: 1}
  - Id: medicine_used
    TitleFormat: MEDICINE USED
    BodyFormat: '{0} is back on their feet.'
    ToneColor: {r: 0.48235294, g: 0.5411765, b: 0.41960785, a: 1}
  - Id: emergency_scavenge_started
    TitleFormat: SCAVENGE STARTED
    BodyFormat: Perimeter sweep will finish in {0}s.
    ToneColor: {r: 0.88235295, g: 0.7058824, b: 0.41568628, a: 1}
  - Id: autosave_enabled
    TitleFormat: AUTOSAVE ON
    BodyFormat: Progress will save automatically.
    ToneColor: {r: 0.48235294, g: 0.5411765, b: 0.41960785, a: 1}
  - Id: autosave_disabled
    TitleFormat: AUTOSAVE OFF
    BodyFormat: Use manual save to preserve progress.
    ToneColor: {r: 0.88235295, g: 0.7058824, b: 0.41568628, a: 1}
  - Id: manual_saved
    TitleFormat: SAVED
    BodyFormat: Camp progress was written to disk.
    ToneColor: {r: 0.48235294, g: 0.5411765, b: 0.41960785, a: 1}
