  NextGoals:
  - Id: first_store
    Title: 'NEXT: ABANDONED STORE'
    Body: Send Mara to the Abandoned Store and bring back the first report.
    CompleteWhenAnyCondition: 0
    Conditions:
    - Type: zone_completions
      Id: abandoned_store
      Value: 1
  - Id: barracks_one
    Title: 'NEXT: UPGRADE BARRACKS'
    Body: Upgrade Barracks to open space for another survivor.
    CompleteWhenAnyCondition: 0
    Conditions:
    - Type: building_level
      Id: barracks
      Value: 1
  - Id: recruit_two
    Title: 'NEXT: RECRUIT A SURVIVOR'
    Body: Use the radio to bring a second survivor into camp.
    CompleteWhenAnyCondition: 0
    Conditions:
    - Type: survivor_count
      Id: ''
      Value: 2
  - Id: workshop_one
    Title: 'NEXT: BUILD WORKSHOP'
    Body: Upgrade Workshop to repair and equip scavenged gear.
    CompleteWhenAnyCondition: 0
    Conditions:
    - Type: building_level
      Id: workshop
      Value: 1
  - Id: demo_signal
    Title: 'FINAL: FIND THE SIGNAL'
    Body: Clear Mutant Tunnel or raise Radio Tower to level 2.
    CompleteWhenAnyCondition: 1
    Conditions:
    - Type: zone_completions
      Id: mutant_tunnel
      Value: 1
    - Type: building_level
      Id: radio_tower
      Value: 2
